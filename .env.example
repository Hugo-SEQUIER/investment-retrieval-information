# Backend database path
AI_EQUITY_DB_PATH=data/discovery.sqlite

# Required for Reddit ingestion
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-equity-discovery/0.1

# X/Twitter ingestion (Scweet)
# Use browser auth token (preferred) and optional custom Scweet DB path.
TWITTER_AUTH_TOKEN=
SCWEET_AUTH_TOKEN=
SCWEET_DB_PATH=scweet_state.db

OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.6-plus

DISCOVERY_AGENT_ENABLED=true
OBSIDIAN_MEMORY_ENABLED=true
OBSIDIAN_MEMORY_ROOT=projects/ai-equity-discovery-agent/research
